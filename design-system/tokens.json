{
  "color": {
    "bg": {
      "canvas": "hsl(var(--background))",
      "surface": "hsl(var(--card))",
      "popover": "hsl(var(--popover))",
      "muted": "hsl(var(--muted))",
      "overlaySoft": "rgba(0, 0, 0, 0.4)",
      "overlayStrong": "rgba(0, 0, 0, 0.8)"
    },
    "text": {
      "primary": "hsl(var(--foreground))",
      "muted": "hsl(var(--muted-foreground))",
      "onPrimary": "hsl(var(--primary-foreground))",
      "onSecondary": "hsl(var(--secondary-foreground))",
      "onCard": "hsl(var(--card-foreground))",
      "onPopover": "hsl(var(--popover-foreground))"
    },
    "border": {
      "default": "hsl(var(--border))",
      "input": "hsl(var(--input))",
      "focusRing": "hsl(var(--ring))"
    },
    "action": {
      "primary": "hsl(var(--primary))",
      "secondary": "hsl(var(--secondary))",
      "accent": "hsl(var(--accent))"
    },
    "status": {
      "danger": "hsl(var(--destructive))",
      "success": "hsl(var(--success))",
      "warning": "hsl(var(--warning))"
    }
  },
  "space": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px",
    "9": "36px",
    "10": "40px",
    "11": "44px",
    "12": "48px",
    "13": "52px",
    "14": "56px",
    "15": "60px",
    "16": "64px",
    "17": "68px",
    "18": "72px",
    "19": "76px",
    "20": "80px",
    "21": "84px",
    "22": "88px",
    "23": "92px",
    "24": "96px"
  },
  "radius": {
    "sm": "calc(var(--radius) - 6px)",
    "md": "calc(var(--radius) - 4px)",
    "lg": "calc(var(--radius) - 2px)",
    "xl": "var(--radius)"
  },
  "shadow": {
    "sm": "shadow-sm",
    "md": "shadow",
    "lg": "shadow-lg",
    "cardLight": "0 1px 3px 0 rgba(0, 0, 0, 0.06), 0 4px 12px -2px rgba(0, 0, 0, 0.08)",
    "cardDark": "0 1px 2px 0 rgba(0, 0, 0, 0.2), 0 4px 12px -2px rgba(0, 0, 0, 0.25)",
    "panelLight": "0 4px 6px -1px rgba(0, 0, 0, 0.08), 0 12px 28px -4px rgba(0, 0, 0, 0.12)",
    "panelDark": "0 4px 6px -1px rgba(0, 0, 0, 0.3), 0 12px 28px -4px rgba(0, 0, 0, 0.4)"
  },
  "typography": {
    "family": {
      "sans": [
        "var(--font-sans)",
        "Inter",
        "ui-sans-serif",
        "system-ui",
        "sans-serif"
      ],
      "mono": [
        "ui-monospace",
        "monospace"
      ]
    },
    "size": {
      "nano": "8px",
      "micro": "9px",
      "xxxs": "10px",
      "xxs": "11px",
      "xs": "12px",
      "xsplus": "13px",
      "sm": "14px",
      "smplus": "15px",
      "lg": "18px"
    },
    "tracking": {
      "label": "0.12em",
      "labelmd": "0.16em",
      "labellg": "0.18em",
      "labelxl": "0.2em"
    },
    "weight": {
      "medium": 500,
      "semibold": 600
    }
  }
}
